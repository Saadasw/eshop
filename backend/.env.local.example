# Local development without Supabase
# Copy this to .env and adjust DATABASE_URL for your local Postgres

# --- Provider Switches (use "local" to bypass Supabase) ---
AUTH_PROVIDER=local
STORAGE_PROVIDER=local

# --- Database (local PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/eshop

# --- JWT ---
SECRET_KEY=local-dev-secret-key-change-in-production

# --- Local Storage ---
LOCAL_STORAGE_DIR=uploads
LOCAL_STORAGE_URL=http://localhost:8000/uploads

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]
